@startuml
skinparam classAttributeIconSize 0
skinparam monochrome true
hide circle

class Point {
  + x: double
  + y: double
}

class Degrees {
  + value: int [0..359]
}

class Distance {
  + value: int [1..100]
  + messageError : String
}

class Angle {
  + value: int [1..180]
  + messageError : String
}

class ProgramRunner {
  - program: Program
  - ctx: ExecutionContext
  - pc: int
  + load(program: Program) : ValidationResult
  + step() : void
  + run() : void
  + reset() : void
}

class ValidationResult {
  + valid: bool
  + messages: List<String>
}

class ProgramSerializer {
  + toLines(p: Program) : List<String>
  + fromLines(lines: List<String>) : Program
}

class Program {
  - actions: List<Action>
  + add(a: Action) : void
  + removeAt(i: int) : void
  + move(from: int, to: int) : void
  + duplicateAt(i: int) : void
  + clear() : void
  + isValid() : ValidationResult
}

class ExecutionContext {
  + cursor: Cursor
  + canvas: Canvas
  + reset() : void
}

class Cursor {
  + position: Point
  + heading: Degrees
  + penDown: bool
}

class Canvas {
  + segments: List<Segment>
  + addSegment(s: Segment) : void
  + clear() : void
}

class Segment {
  + start: Point
  + end: Point
}

abstract class Action <<abstract>> {
  + execute(ctx: ExecutionContext) : void
  + validate() : ValidationResult
  + defaultLabel() : String
}

class MoveForward {
  - distance: Distance
}

class TurnLeft {
  - angle: Angle
}

class TurnRight {
  - angle: Angle
}

class PenUp {
}

class PenDown {
}

' Relations principales
Program "1" o-right- "*" Action : actions (ordre)
Action <|-- MoveForward
Action <|-- TurnLeft
Action <|-- TurnRight
Action <|-- PenUp
Action <|-- PenDown

' Dépendances
ProgramRunner --> Program
ProgramRunner --> ExecutionContext
ProgramRunner ..> ValidationResult

ProgramSerializer ..> Program
Program ..> ValidationResult

Action ..> ValidationResult
Action ..> ExecutionContext

' Composition / Aggrégation
ExecutionContext "1" o-- "1" Cursor
ExecutionContext "1" o-- "1" Canvas

Canvas "1" o-- "*" Segment

' Associations simples
MoveForward --> Distance
TurnLeft --> Angle
TurnRight --> Angle
Cursor --> Point
Cursor --> Degrees
Segment --> Point

@enduml